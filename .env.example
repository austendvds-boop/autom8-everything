# =============================================
# Core site settings
# =============================================
NEXT_PUBLIC_SITE_URL=https://autom8everything.com
NEXT_PUBLIC_CADENCE_API_URL=https://cadence-v2-production.up.railway.app

# Business identity (required for production NAP consistency)
NEXT_PUBLIC_BUSINESS_NAME=Autom8 Everything
NEXT_PUBLIC_BUSINESS_EMAIL=hello@autom8everything.com
# Leave phone empty until final verified line is approved.
NEXT_PUBLIC_BUSINESS_PHONE_DISPLAY=
NEXT_PUBLIC_BUSINESS_PHONE_E164=
# Street + postal are optional for service-area businesses; set when you want full address published.
NEXT_PUBLIC_BUSINESS_STREET_ADDRESS=
NEXT_PUBLIC_BUSINESS_POSTAL_CODE=
NEXT_PUBLIC_BUSINESS_CITY=Phoenix
NEXT_PUBLIC_BUSINESS_STATE=AZ
NEXT_PUBLIC_BUSINESS_COUNTRY=US
NEXT_PUBLIC_BUSINESS_SERVICE_AREA_LABEL=Serving Arizona and remote clients across the U.S.

# Social profiles (optional; leave empty to hide icon)
NEXT_PUBLIC_SOCIAL_TWITTER=
NEXT_PUBLIC_SOCIAL_GITHUB=
NEXT_PUBLIC_SOCIAL_LINKEDIN=

# =============================================
# Review Funnel - database + auth (required)
# =============================================
# Neon Postgres connection string used by Drizzle + Review Funnel APIs.
DATABASE_URL=
# 64 hex chars (32 bytes). Used for encryption at rest.
RF_ENCRYPTION_KEY=
# 32+ chars. Used for Review Funnel login/session JWT signing.
RF_JWT_SECRET=

# Magic-link/session behavior (optional; defaults shown)
RF_MAGIC_LINK_TTL_MINUTES=15
RF_SESSION_TTL_HOURS=24

# Optional path to a local Gmail credentials file in "email|appPassword" format.
# If omitted, Review Funnel can still use RF_SMTP_USER/RF_SMTP_PASS or GMAIL_SMTP_USER/GMAIL_SMTP_APP_PASSWORD.
RF_GMAIL_CREDENTIALS_PATH=
# Optional SMTP fallback credentials for magic-link email sending.
RF_SMTP_USER=
RF_SMTP_PASS=
GMAIL_SMTP_USER=
GMAIL_SMTP_APP_PASSWORD=

# =============================================
# Review Funnel - Google integrations
# =============================================
# Required for Google Calendar connect flow.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional override. If blank, app uses <NEXT_PUBLIC_SITE_URL>/api/review-funnel/google/callback
GOOGLE_REDIRECT_URI=

# Required for business lookup during signup.
GOOGLE_PLACES_API_KEY=
# Optional public fallback for places search route.
NEXT_PUBLIC_GOOGLE_PLACES_API_KEY=

# =============================================
# Review Funnel - Twilio (text messages)
# =============================================
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Provide either a direct Twilio number OR a Messaging Service SID.
RF_TWILIO_PHONE_NUMBER=
RF_TWILIO_MESSAGING_SERVICE_SID=

# Quiet hours for outbound texts (24h clock, inclusive start/exclusive end)
RF_QUIET_HOURS_START=21
RF_QUIET_HOURS_END=9

# =============================================
# Review Funnel - Stripe billing
# =============================================
STRIPE_SECRET_KEY=
RF_STRIPE_WEBHOOK_SECRET=
RF_STRIPE_PRICE_STARTER=
RF_STRIPE_PRICE_GROWTH=

# =============================================
# Review Funnel - internal protection + admin
# =============================================
# Shared secret required by cron routes (/api/review-funnel/cron/*)
CRON_SECRET=
# Password used by /review-funnel/admin login route.
RF_ADMIN_SECRET=

# =============================================
# Platform - unified client management
# =============================================
A8_ADMIN_SECRET=
A8_JWT_SECRET=
CADENCE_API_URL=https://cadence-v2-production.up.railway.app
PORTAL_API_SECRET=

# Portal checkout + billing provisioning
PORTAL_STRIPE_WEBHOOK_SECRET=
PORTAL_STRIPE_PRICE_CADENCE_STARTER=
